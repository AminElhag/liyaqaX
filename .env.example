# ── PostgreSQL ────────────────────────────────────────────────────────────
# Database credentials used by docker-compose and the backend application.
POSTGRES_USER=arena
POSTGRES_PASSWORD=changeme
POSTGRES_DB=arena_db

# ── Redis ─────────────────────────────────────────────────────────────────
# Optional. Leave blank for no password (local dev only).
REDIS_PASSWORD=
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Backend ───────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/arena_db
SPRING_DATASOURCE_USERNAME=arena
SPRING_DATASOURCE_PASSWORD=changeme
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

JWT_SECRET=
JWT_EXPIRY_SECONDS=3600

# ── Frontend — web-nexus (Vite) ───────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_APP_ENV=development

# ── Frontend — web-pulse (Vite) ───────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_APP_ENV=development

# ── Frontend — web-coach (Vite) ───────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_APP_ENV=development

# ── Frontend — web-arena (Vite) ───────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_APP_ENV=development

# ── Email (SMTP) ──────────────────────────────────────────────────────────
# In dev: Mailpit catches all emails at localhost:8025 (SMTP on 1025).
# In prod: configure a real SMTP relay.
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@liyaqa.com

# ── External services ─────────────────────────────────────────────────────
QOYOD_API_KEY=
ZATCA_ENV=sandbox
ZATCA_CERTIFICATE=
ZATCA_API_BASE_URL=https://gw-apic-gov.gazt.gov.sa/e-invoicing/developer-portal
# Generate with: openssl rand -base64 32
ZATCA_ENCRYPTION_KEY=
